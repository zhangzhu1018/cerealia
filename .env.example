# Caviar CRM 后端环境变量配置

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=caviar_crm

FLASK_ENV=development
SECRET_KEY=caviar-crm-secret-change-me
CORS_ORIGINS=*
SQLALCHEMY_ECHO=False

# ── 邮件发送（SMTP，可选）─────────────────────────────
# 默认发件账号参数，首次配置后可通过前端管理更多账号
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_NAME=Cerealia Caviar
EMAIL_FROM_ADDRESS=sales@cerealia.com
EMAIL_USE_TLS=true
EMAIL_DEFAULT_INTERVAL=30
EMAIL_DAILY_LIMIT=200
